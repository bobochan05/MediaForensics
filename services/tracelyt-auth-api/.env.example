NODE_ENV=development
PORT=4100
APP_BASE_URL=http://localhost:4100
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tracelyt_auth

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m

EMAIL_PROVIDER=resend
EMAIL_FROM=Tracelyt Security <security@tracelyt.ai>
RESEND_API_KEY=
SENDGRID_API_KEY=

EMAIL_VERIFICATION_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=30
VERIFICATION_EMAIL_COOLDOWN_SECONDS=300
PASSWORD_RESET_COOLDOWN_SECONDS=300
LOGIN_ALERT_COOLDOWN_HOURS=24
EMAIL_QUEUE_POLL_INTERVAL_MS=1500
EMAIL_QUEUE_LOCK_TIMEOUT_SECONDS=60
EMAIL_QUEUE_MAX_ATTEMPTS=5
EMAIL_QUEUE_BASE_BACKOFF_SECONDS=30

CORS_ORIGIN=http://localhost:3000
