# Flask/API runtime
FLASK_SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000
DASHBOARD_FRONTEND_URL=http://localhost:3000
INFERENCE_TIMEOUT_SECONDS=180
MAX_UPLOAD_SIZE_MB=50
SENDGRID_API_KEY=replace-with-your-sendgrid-api-key
SENDER_EMAIL=verified-sender@example.com
TRACELYT_ALERT_COOLDOWN_MINUTES=30

# Layer 3 service
LAYER3_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/deepfake_layer3
LAYER3_LAYER2_TRACK_ENDPOINT=http://127.0.0.1:8001/track
LAYER3_LAYER2_TIMEOUT_SECONDS=30
LAYER3_RETRY_ATTEMPTS=3
LAYER3_RETRY_BACKOFF_SECONDS=1
LAYER3_MAX_CALLS_PER_DAY=5
LAYER3_MAX_CALLS_PER_MONTH=250
LAYER3_RISK_OVERRIDE_THRESHOLD=0.8
LAYER3_VIRAL_SOURCE_THRESHOLD=25
LAYER3_MAX_SOURCES_PER_RUN=5000
LAYER3_LOG_LEVEL=INFO
LAYER3_JSON_LOGS=1

# Auth
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
AUTH_DATABASE_URL=sqlite:///artifacts/auth.db
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14
BCRYPT_ROUNDS=12
AUTH_RATE_LIMIT_PER_MINUTE=5
AUTH_GUEST_MAX_TRIES=5
AUTH_ACCESS_COOKIE_NAME=tracelyt_access_token
AUTH_REFRESH_COOKIE_NAME=tracelyt_refresh_token
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
GOOGLE_OAUTH_CLIENT_ID=

